// Vitest Snapshot v1, https://vitest.dev/guide/snapshot.html

exports[`CardView legacy render stays byte-identical (golden) > flat clarify card 1`] = `"<div class="card-col" style="--stage-color: var(--clarify);"><div class="card-head"><div class="head-kicker"><span class="stage-tag">Clarify</span></div><h1 class="card-headline">Pick a detail option</h1><div class="source-strip" aria-label="Decision source"><span><span class="source-label">Session</span><strong>Plan QA</strong></span><span><svg class="lucide lucide-folder-git2 lucide-folder-git-2"></svg><span class="source-label">Project</span><strong>boardroom</strong></span><span><svg class="lucide lucide-bot"></svg><span class="source-label">Agent</span><strong>codex</strong></span><span title="Tuesday, Jun 16, 2026, 12:00:00 PM"><svg class="lucide lucide-calendar-clock"></svg><span class="source-label">Created</span><strong class="source-time">Tue Jun 16 12:00 PM</strong></span></div><div class="cockpit-stats"><span><svg class="lucide lucide-panel-right"></svg>1 decision</span><span><svg class="lucide lucide-workflow"></svg>0 linked visuals</span><span><svg class="lucide lucide-layers"></svg>2 blocks</span></div><p class="stage-role">Set the direction so the agent can plan — pick an option, or write your own.</p><details class="stage-guide"><summary>How to decide here</summary><ul><li>You're scoping, not signing off the final build — answer what unblocks the plan.</li><li>No option fits? Use “Other…” to say it in your own words.</li><li>A note on any choice gives the agent extra context.</li></ul></details></div><section class="decision-sheet" aria-label="Decision sheet"><div class="sheet-head"><div><span class="canvas-label">Decision sheet</span><h2>0/1 done</h2><p class="sheet-source">Plan QA</p></div><span class="dock-status">pending</span></div><div class="decision-row"><section class="dsec"><div class="dsec-label">Decision 1 of 1</div><div class="dsec-topline"><h2 class="dsec-prompt">Which detail should the agent use?</h2><button class="rec-quick" aria-label="Use recommended: Detail A"><svg class="lucide lucide-star"></svg>Use rec</button></div><div class="opts"><button class="opt">Detail A<svg class="lucide lucide-star star"></svg></button><button class="opt">Detail B</button><button class="opt" title="Answer in your own words"><svg class="lucide lucide-pen-line"></svg>Other…</button></div><textarea class="note" aria-label="Note for the agent" placeholder="Optional note for the agent"></textarea><div class="attach-field"><input class="attach-input" multiple="" type="file"><button type="button" class="attach-btn" aria-label="Attach file to note"><svg class="lucide lucide-paperclip"></svg>Attach</button></div></section><aside class="question-context" aria-label="Decision 1 context"><div class="question-context-head"><div><span class="canvas-label">Question context</span><h3>Decision 1</h3></div><span class="canvas-count">0 blocks</span></div><p class="context-empty">No question-local context.</p></aside></div><section class="global-context" aria-label="Global card context"><div class="global-context-head"><span class="canvas-label">Global context</span><span class="canvas-count">2 blocks</span></div><div id="block-choice" class="block"><div class="block-kind"><svg class="lucide lucide-scale"></svg>Trade-offs<span class="title">· Submit layout choice</span></div><div class="compare"><div class="compare-opt rec"><span class="rec-badge"><svg class="lucide lucide-badge-check"></svg>rec</span><div class="compare-label">Fix shared submit CSS</div><div class="pro"><span>+</span>Keeps actions visible</div></div><div class="compare-opt"><div class="compare-label">Leave it</div><div class="con"><span>−</span>Proceed button can be pushed offscreen</div></div></div></div><div id="block-global" class="block"><div class="block-kind"><svg class="lucide lucide-file-text"></svg>Context<span class="title">· Global constraints</span></div><div><div class="prose clamped"><p>Applies to the whole card.</p></div></div></div></section><div class="submit-bar"><span class="submit-state">0/1 answered</span><button class="submit" disabled="">Submit decisions<svg class="lucide lucide-arrow-right"></svg></button></div></section></div>"`;

exports[`CardView legacy render stays byte-identical (golden) > flat plan card 1`] = `"<div class="card-col" style="--stage-color: var(--plan);"><div class="card-head"><div class="head-kicker"><span class="stage-tag">Plan approval</span></div><h1 class="card-headline">Fix plan submit layout</h1><div class="source-strip" aria-label="Decision source"><span><span class="source-label">Session</span><strong>Plan QA</strong></span><span><svg class="lucide lucide-folder-git2 lucide-folder-git-2"></svg><span class="source-label">Project</span><strong>boardroom</strong></span><span><svg class="lucide lucide-bot"></svg><span class="source-label">Agent</span><strong>codex</strong></span><span title="Tuesday, Jun 16, 2026, 12:00:00 PM"><svg class="lucide lucide-calendar-clock"></svg><span class="source-label">Created</span><strong class="source-time">Tue Jun 16 12:00 PM</strong></span></div><div class="cockpit-stats"><span><svg class="lucide lucide-panel-right"></svg>1 decision</span><span><svg class="lucide lucide-workflow"></svg>1 linked visual</span><span><svg class="lucide lucide-layers"></svg>2 blocks</span></div><p class="stage-role">Approve the approach to proceed — or send it back with changes.</p><details class="stage-guide"><summary>How to decide here</summary><ul><li>Approving IS agreeing to the plan’s decisions — it’s the submit, not a separate gate.</li><li>Each decision is a fork in how it gets built; pick what you want.</li><li>“Send back” with a note halts it — the note becomes the agent’s next instruction.</li></ul></details></div><section class="decision-sheet" aria-label="Decision sheet"><div class="sheet-head"><div><span class="canvas-label">Decision sheet</span><h2>0/1 done</h2><p class="sheet-source">Plan QA</p></div><span class="dock-status">pending</span></div><div class="decision-row"><section class="dsec"><div class="dsec-label">Decision 1 of 1</div><div class="dsec-topline"><h2 class="dsec-prompt">Proceed with the submit layout fix?</h2><button class="rec-quick" aria-label="Use recommended: Approve fix scope"><svg class="lucide lucide-star"></svg>Use rec</button></div><div class="linked-evidence"><span>Evidence</span><a href="#block-scope-choice">Submit layout choice</a></div><div class="opts"><button class="opt">Approve fix scope<svg class="lucide lucide-star star"></svg></button><button class="opt">Revise</button><button class="opt" title="Answer in your own words"><svg class="lucide lucide-pen-line"></svg>Other…</button></div><textarea class="note" aria-label="Note for the agent" placeholder="Optional note for the agent"></textarea><div class="attach-field"><input class="attach-input" multiple="" type="file"><button type="button" class="attach-btn" aria-label="Attach file to note"><svg class="lucide lucide-paperclip"></svg>Attach</button></div></section><aside class="question-context" aria-label="Decision 1 context"><div class="question-context-head"><div><span class="canvas-label">Question context</span><h3>Decision 1</h3></div><span class="canvas-count">1 block</span></div><div id="block-scope-choice" class="block highlight"><div class="block-kind"><svg class="lucide lucide-scale"></svg>Trade-offs<span class="title">· Submit layout choice</span></div><div class="compare"><div class="compare-opt rec"><span class="rec-badge"><svg class="lucide lucide-badge-check"></svg>rec</span><div class="compare-label">Fix shared submit CSS</div><div class="pro"><span>+</span>Keeps actions visible</div></div><div class="compare-opt"><div class="compare-label">Leave it</div><div class="con"><span>−</span>Proceed button can be pushed offscreen</div></div></div></div></aside></div><section class="global-context" aria-label="Global card context"><div class="global-context-head"><span class="canvas-label">Global context</span><span class="canvas-count">1 block</span></div><div id="block-global" class="block"><div class="block-kind"><svg class="lucide lucide-file-text"></svg>Context<span class="title">· Global constraints</span></div><div><div class="prose clamped"><p>Applies to the whole card.</p></div></div></div></section><div class="submit-bar"><button class="submit ghost">Send back…</button><span class="submit-state">0/1 agreed</span><button class="submit" disabled="">Approve plan &amp; proceed<svg class="lucide lucide-arrow-right"></svg></button></div></section></div>"`;

exports[`CardView legacy render stays byte-identical (golden) > flat results card 1`] = `"<div class="card-col" style="--stage-color: var(--results);"><div class="card-head"><div class="head-kicker"><span class="stage-tag">Results review</span></div><h1 class="card-headline">Review completed work</h1><div class="source-strip" aria-label="Decision source"><span><span class="source-label">Session</span><strong>Plan QA</strong></span><span><svg class="lucide lucide-folder-git2 lucide-folder-git-2"></svg><span class="source-label">Project</span><strong>boardroom</strong></span><span><svg class="lucide lucide-bot"></svg><span class="source-label">Agent</span><strong>codex</strong></span><span title="Tuesday, Jun 16, 2026, 12:00:00 PM"><svg class="lucide lucide-calendar-clock"></svg><span class="source-label">Created</span><strong class="source-time">Tue Jun 16 12:00 PM</strong></span></div><div class="cockpit-stats"><span><svg class="lucide lucide-panel-right"></svg>2 decisions</span><span><svg class="lucide lucide-workflow"></svg>0 linked visuals</span><span><svg class="lucide lucide-layers"></svg>2 blocks</span></div><p class="stage-role">Sign off on what the agent did — trust the proof, flag what’s wrong.</p><details class="stage-guide"><summary>How to decide here</summary><ul><li>You’re checking intent &amp; safety, not re-running the work — expand a claim only if you doubt it.</li><li>The chip is the proof (tests, diff); approve when it holds.</li><li>Deny a claim to reject it — your note is the fix instruction the agent gets back.</li></ul></details></div><div class="results"><div class="results-head"><svg class="lucide lucide-list-checks"></svg><span class="results-title">Agent claims 2 things done</span><span class="results-progress">0 of 2 reviewed</span><span style="flex: 1 1 0%;"></span><button class="approve-all">Approve all</button></div><div class="claim"><div class="claim-row"><svg class="lucide lucide-circle claim-icon idle"></svg><span class="claim-text">Claim one</span><span class="verdicts"><button class="vbtn approve" aria-label="Approve"><svg class="lucide lucide-check"></svg><span>Approve</span></button><button class="vbtn revise" aria-label="Revise"><svg class="lucide lucide-pencil"></svg><span>Revise</span></button><button class="vbtn reject" aria-label="Reject"><svg class="lucide lucide-x"></svg><span>Reject</span></button></span></div><div class="attach-field"><input class="attach-input" multiple="" type="file"><button type="button" class="attach-btn" aria-label="Attach file to claim 1"><svg class="lucide lucide-paperclip"></svg>Attach</button></div></div><div class="claim"><div class="claim-row"><svg class="lucide lucide-circle claim-icon idle"></svg><span class="claim-text">Claim two</span><span class="verdicts"><button class="vbtn approve" aria-label="Approve"><svg class="lucide lucide-check"></svg><span>Approve</span></button><button class="vbtn revise" aria-label="Revise"><svg class="lucide lucide-pencil"></svg><span>Revise</span></button><button class="vbtn reject" aria-label="Reject"><svg class="lucide lucide-x"></svg><span>Reject</span></button></span></div><div class="attach-field"><input class="attach-input" multiple="" type="file"><button type="button" class="attach-btn" aria-label="Attach file to claim 2"><svg class="lucide lucide-paperclip"></svg>Attach</button></div></div></div><div class="results-finish"><textarea class="note addon" aria-label="Add instructions for the agent" placeholder="Add anything for the agent (optional) — sent whether or not you mark complete"></textarea><div class="attach-field"><input class="attach-input" multiple="" type="file"><button type="button" class="attach-btn" aria-label="Attach file to your add-on"><svg class="lucide lucide-paperclip"></svg>Attach</button></div><div class="submit-bar results-submit"><span class="submit-state">0/2 reviewed</span><button class="submit">Keep going<svg class="lucide lucide-arrow-right"></svg></button></div></div></div>"`;

exports[`CardView legacy render stays byte-identical (golden) > plan card with only the verdict decision (zero visible decisions) 1`] = `"<div class="card-col" style="--stage-color: var(--plan);"><div class="card-head"><div class="head-kicker"><span class="stage-tag">Plan approval</span></div><h1 class="card-headline">Fix plan submit layout</h1><div class="source-strip" aria-label="Decision source"><span><span class="source-label">Session</span><strong>Plan QA</strong></span><span><svg class="lucide lucide-folder-git2 lucide-folder-git-2"></svg><span class="source-label">Project</span><strong>boardroom</strong></span><span><svg class="lucide lucide-bot"></svg><span class="source-label">Agent</span><strong>codex</strong></span><span title="Tuesday, Jun 16, 2026, 12:00:00 PM"><svg class="lucide lucide-calendar-clock"></svg><span class="source-label">Created</span><strong class="source-time">Tue Jun 16 12:00 PM</strong></span></div><div class="cockpit-stats"><span><svg class="lucide lucide-panel-right"></svg>0 decisions</span><span><svg class="lucide lucide-workflow"></svg>0 linked visuals</span><span><svg class="lucide lucide-layers"></svg>1 block</span></div><p class="stage-role">Approve the approach to proceed — or send it back with changes.</p><details class="stage-guide"><summary>How to decide here</summary><ul><li>Approving IS agreeing to the plan’s decisions — it’s the submit, not a separate gate.</li><li>Each decision is a fork in how it gets built; pick what you want.</li><li>“Send back” with a note halts it — the note becomes the agent’s next instruction.</li></ul></details></div><section class="decision-sheet" aria-label="Decision sheet"><div class="sheet-head"><div><span class="canvas-label">Decision sheet</span><h2>Ready to submit</h2><p class="sheet-source">Plan QA</p></div><span class="dock-status">pending</span></div><section class="global-context" aria-label="Global card context"><div class="global-context-head"><span class="canvas-label">Global context</span><span class="canvas-count">1 block</span></div><div id="block-ph" class="block"><div class="block-kind"><svg class="lucide lucide-milestone"></svg>Phases</div><div class="phases"><div style="display: flex; align-items: center; gap: 10px;"><div class="phase"><span class="phase-num">01</span><span class="phase-title">Phase 1</span></div></div></div></div></section><div class="submit-bar"><button class="submit ghost">Send back…</button><span class="submit-state">agreed on all</span><button class="submit">Approve plan &amp; proceed<svg class="lucide lucide-arrow-right"></svg></button></div></section></div>"`;
