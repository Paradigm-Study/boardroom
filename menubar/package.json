{
  "name": "boardroom-menubar",
  "version": "0.1.0",
  "private": true,
  "description": "macOS menu-bar shell for the boardroom dashboard",
  "main": "main.js",
  "scripts": {
    "appicon": "node make-icons.mjs && iconutil -c icns -o build/icon.icns build/boardroom.iconset",
    "start": "electron .",
    "pack": "npm run appicon && electron-builder --mac --dir",
    "postinstall": "node make-icons.mjs",
    "icons": "node make-icons.mjs"
  },
  "devDependencies": {
    "@resvg/resvg-js": "^2.6.2",
    "electron": "^33.0.0",
    "electron-builder": "^26.15.3"
  },
  "dependencies": {
    "menubar": "^9.5.1"
  },
  "build": {
    "appId": "com.boardroom.menubar",
    "productName": "boardroom",
    "directories": {
      "output": "release"
    },
    "files": [
      "main.js",
      "iconTemplate.png",
      "iconTemplate@2x.png",
      "package.json"
    ],
    "mac": {
      "icon": "build/icon.icns",
      "category": "public.app-category.developer-tools",
      "target": "dir",
      "identity": null,
      "extendInfo": {
        "LSUIElement": 1
      }
    }
  }
}
